{
  "name": "jobpilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:jsearch": "vitest run --config vitest.integration.config.ts jsearch",
    "test:integration:adzuna": "vitest run --config vitest.integration.config.ts adzuna",
    "test:integration:openai": "vitest run --config vitest.integration.config.ts openai",
    "test:integration:resend": "vitest run --config vitest.integration.config.ts resend",
    "test:integration:pipeline": "vitest run --config vitest.integration.config.ts full-pipeline",
    "test:integration:supabase": "vitest run --config vitest.integration.config.ts supabase-queries",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:desktop": "playwright test --project desktop-chrome",
    "test:e2e:mobile": "playwright test --project mobile-chrome",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:unit": "vitest run src/",
    "test:all": "vitest run src/ && playwright test --project desktop-chrome"
  },
  "dependencies": {
    "@dnd-kit/abstract": "^0.2.3",
    "@dnd-kit/helpers": "^0.2.3",
    "@dnd-kit/react": "^0.2.3",
    "@mendable/firecrawl-js": "^4.18.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-email/components": "1.0.7",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.93.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "docx": "^9.6.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-intl": "^4.8.1",
    "next-themes": "^0.4.6",
    "openai": "^6.17.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "resend": "^6.9.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.30",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^27.4.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
